# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Business Contact
VITE_WHATSAPP_NUMBER=91XXXXXXXXXX
VITE_WHATSAPP_DISPLAY=+91 XXXXX XXXXX

# Payments
VITE_UPI_ID=yourname@upi
VITE_UPI_NUMBER=XXXXXXXXXX
VITE_UPI_DISPLAY=XXXXXXXXXX (GPay / PhonePe / UPI)

# Admin
VITE_ADMIN_PIN=XXXX

# Domain (set to your custom domain to enable subdomain routing)
# admin.skctreats.in  → /admin/*
# agents.skctreats.in → /agent/*
# skctreats.in        → / (storefront)
VITE_APP_DOMAIN=skctreats.in

# WhatsApp Links
VITE_WA_GROUP_LINK=https://chat.whatsapp.com/XXXXXXXXXXXXXXXXXXXXXXX
VITE_WA_CHANNEL_LINK=https://whatsapp.com/channel/XXXXXXXXXXXXXXXXXXXXXXX
VITE_WA_TRACKING_LINK=https://chat.whatsapp.com/XXXXXXXXXXXXXXXXXXXXXXX
